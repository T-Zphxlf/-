<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme for TV -->
    <style name="VoiceTypeTheme" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowShowWallpaper">true</item>
    </style>

    <!-- TV Keyboard key style -->
    <style name="TvKeyStyle">
        <item name="android:layout_width">52dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/key_text_color</item>
        <item name="android:background">@drawable/key_background</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Special key style (voice, space, enter, delete) -->
    <style name="TvSpecialKeyStyle" parent="@style/TvKeyStyle">
        <item name="android:layout_width">108dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:background">@drawable/key_special_background</item>
    </style>

    <!-- Voice key style - the most prominent -->
    <style name="TvVoiceKeyStyle" parent="@style/TvKeyStyle">
        <item name="android:layout_width">220dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/voice_key_text</item>
        <item name="android:background">@drawable/key_voice_background</item>
    </style>

    <!-- Number key style (9-grid) -->
    <style name="TvNumKeyStyle" parent="@style/TvKeyStyle">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:textSize">20sp</item>
    </style>

    <!-- Candidate text style -->
    <style name="CandidateStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/candidate_text</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:background">@drawable/candidate_background</item>
    </style>
</resources>
