<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Listening state (red pulsing) -->
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/voice_key_listening_bg" />
            <corners android:radius="8dp" />
            <stroke android:width="3dp" android:color="#FFFF5252" />
        </shape>
    </item>
    <!-- Focused but not listening -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/voice_key_focused_bg" />
            <corners android:radius="8dp" />
            <stroke android:width="3dp" android:color="#FF66BB6A" />
        </shape>
    </item>
    <!-- Default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/voice_key_normal_bg" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
